# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=3000

# Gmail account used to send emails
GMAIL_USER=yourbusiness@gmail.com

# Gmail App Password (NOT your regular password)
# Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where appointment emails should be delivered (can be same as GMAIL_USER)
BUSINESS_EMAIL=yourbusiness@gmail.com

# Your Angular dev URL (for CORS — use your real domain in production)
FRONTEND_ORIGIN=https://furbabiesgroom.com
